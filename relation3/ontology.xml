<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:dc="http://purl.org/dc/elements/1.1/"
    xmlns:dcterms="http://purl.org/dc/terms/"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:schema="https://schema.org/"
    xmlns:mgs="https://gams.uni-graz.at/o:mgs.ontology#"
    >

    <!-- Ontology Header -->
    <owl:Ontology rdf:about="https://gams.uni-graz.at/o:mgs.ontology">
        <owl:versionInfo>V 0.1, 2026-03-01</owl:versionInfo>
        <dcterms:identifier>o:mgs.ontology</dcterms:identifier>

        <dc:creator>Selina Galka; Project Team</dc:creator>
        <dcterms:title>Ontology for MGS Persons and Relations</dcterms:title>
        <rdfs:comment>
            Minimal ontology for persons, kinship/social relations, and certainty metadata for assertions.
        </rdfs:comment>
        <owl:imports rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
    </owl:Ontology>
    
    <!-- Classes -->

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#Person">
        <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:comment>A person entity in the MGS register.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="https://schema.org/Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#RelationshipMention">
        <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <rdfs:label xml:lang="en">Relationship Mention</rdfs:label>
        <rdfs:label xml:lang="de">Beziehungserwähnung</rdfs:label>
        <rdfs:comment>A text passage (TEI seg) in which a kinship or social relation between persons is mentioned.</rdfs:comment>
    </rdf:Description>

    
    <!-- PersonLink properties used in this dataset (imported via owl:imports above).
         Stubs below document which terms are referenced; their full definitions are in PersonLink. -->

    <rdf:Description rdf:about="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl#ChildOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
        <rdfs:label xml:lang="en">child of</rdfs:label>
    </rdf:Description>

    <rdf:Description rdf:about="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl#ParentOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
        <rdfs:label xml:lang="en">parent of</rdfs:label>
    </rdf:Description>

    <rdf:Description rdf:about="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl#SiblingOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
        <rdfs:label xml:lang="en">sibling of</rdfs:label>
    </rdf:Description>

    <rdf:Description rdf:about="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl#SpouseOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
        <rdfs:label xml:lang="en">spouse of</rdfs:label>
    </rdf:Description>

    <rdf:Description rdf:about="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl#CousinOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://cedric.cnam.fr/isid/ontologies/PersonLink.owl"/>
        <rdfs:label xml:lang="en">cousin of</rdfs:label>
    </rdf:Description>

    <!-- Object Properties -->

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#relationshipMention">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">relationship mention</rdfs:label>
        <rdfs:label xml:lang="de">Beziehungserwähnung</rdfs:label>
        <rdfs:comment>Links a person relation to the text passage (RelationshipMention) in which it is mentioned.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#RelationshipMention"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#occursIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">occurs in</rdfs:label>
        <rdfs:comment>Links a person to a text document or passage in which they are mentioned.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <!-- RelativeOf: symmetric (broad) -->
    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#RelativeOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">relative of</rdfs:label>
        <rdfs:comment>Broad kinship relation (unspecified).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>
    
    <!-- SisterInLawOf / BrotherInLawOf: symmetric is not always logically safe across cultures,
       but in practice most projects treat it as symmetric. If you prefer: remove SymmetricProperty. -->
    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#SisterInLawOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">sister-in-law of</rdfs:label>
        <rdfs:comment>Person A is the sister-in-law of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#BrotherInLawOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">brother-in-law of</rdfs:label>
        <rdfs:comment>Person A is the brother-in-law of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#MotherInLawOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">mother-in-law of</rdfs:label>
        <rdfs:comment>Person A is the mother-in-law of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#FatherInLawOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">father-in-law of</rdfs:label>
        <rdfs:comment>Person A is the father-in-law of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#AuntOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">aunt of</rdfs:label>
        <rdfs:comment>Person A is the aunt of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#UncleOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:label xml:lang="en">uncle of</rdfs:label>
        <rdfs:comment>Person A is the uncle of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#CousinOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">cousin of</rdfs:label>
        <rdfs:comment>Person A is the cousin of Person B.</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
    </rdf:Description>
    
    
    <!-- Datatype Properties -->

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#faith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">faith</rdfs:label>
        <rdfs:label xml:lang="de">Konfession</rdfs:label>
        <rdfs:comment>Religious denomination of a person (from TEI tei:faith).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#description">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
        <rdfs:comment>Short biographical description of a person (from TEI note[@type='description']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#confession">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">confession</rdfs:label>
        <rdfs:comment>Confessional note (from TEI note[@type='confession']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#conversion">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">conversion</rdfs:label>
        <rdfs:comment>Religious conversion note (from TEI note[@type='conversion']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#conversion_year">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">conversion year</rdfs:label>
        <rdfs:comment>Year of religious conversion (from TEI note[@type='conversion_year']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#cleric">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">cleric</rdfs:label>
        <rdfs:comment>Note on clerical status (from TEI note[@type='cleric']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#vienna">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">Vienna</rdfs:label>
        <rdfs:comment>Note on presence or activity in Vienna (from TEI note[@type='vienna']).</rdfs:comment>
        <rdfs:domain rdf:resource="https://gams.uni-graz.at/o:mgs.ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#cert">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">certainty</rdfs:label>
        <rdfs:comment>Certainty value taken from TEI @cert (e.g. high/medium/low).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>

    <rdf:Description rdf:about="https://gams.uni-graz.at/o:mgs.ontology#evidence">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:label xml:lang="en">evidence</rdfs:label>
        <rdfs:comment>Evidence note for an assertion (e.g. from TEI @evidence).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </rdf:Description>
    
</rdf:RDF>